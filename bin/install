#!/usr/bin/env bash

set -e

echo "Install Dotfiles"
echo ""
echo "This will install/update your terminal setup"
echo ""
read -p "Continue? (y/n) " -n 1 -r
echo ""

if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo ""
    echo "Cancelled"
    echo ""
    exit 0
fi

echo "Installing Oh My Zsh"

if [ -d ~/.oh-my-zsh ]; then
    echo "Oh My Zsh already installed, skipping..."
else
    curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh | sh -s -- --unattended
    echo "Oh My Zsh installed"
fi

# Homebrew
echo "Installing Homebrew"

if ! command -v brew &>/dev/null; then
    if /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"; then
        
        BREW_LINE='eval "$(/opt/homebrew/bin/brew shellenv)"'
        grep -qxF "$BREW_LINE" ~/.zprofile || echo "$BREW_LINE" >> ~/.zprofile
        
        eval "$(/opt/homebrew/bin/brew shellenv)"

        echo "Homebrew installed"
    else
        echo "Homebrew installation failed"
    fi
else
    echo "Homebrew already installed"
fi

echo "Installing packages from Brewfile"
brew bundle --file=~/.dotfiles/home/Brewfile || echo "Some packages failed (likely already installed)"
echo "Brewfile processed"

# Symlinks
echo ""
echo "Creating symlinks"

ln -sf ~/.dotfiles/home/.gitconfig ~/.gitconfig
ln -sf ~/.dotfiles/home/.zshrc ~/.zshrc
ln -sf ~/.dotfiles/home/.vimrc ~/.vimrc

mkdir -p ~/Library/Application\ Support/Code/User
ln -sf ~/.dotfiles/config/vscode/settings.json ~/Library/Application\ Support/Code/User/settings.json
ln -sf ~/.dotfiles/config/vscode/keybindings.json ~/Library/Application\ Support/Code/User/keybindings.json

mkdir -p ~/.config/alacritty
ln -sf ~/.dotfiles/config/alacritty/alacritty.toml ~/.config/alacritty/alacritty.toml

mkdir -p ~/.config/tmux
ln -sf ~/.dotfiles/config/tmux/tmux.conf ~/.config/tmux/tmux.conf

echo "Symlinks created"

echo "Run rbenv init"
~/.dotfiles/bin/rbenv-init

echo "Run nvm init"
curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash

echo ""
echo "Installation complete!"
echo ""
echo "Next steps:"
echo "  • Install a ruby version (rbenv install -l to list latest)"
echo "      - rbenv install 3.4.9"
echo "      - rbenv global 3.4.9 "
echo "  • Install a node version"
echo "      • Install a node version"
echo "      - nvm install --lts"
echo ""
